{
  "calibration": {
    "mode": "free"
  },
  "data": {
    "signals": [
      "ppg"
    ],
    "val_fraction": 0.2
  },
  "decode": {
    "strategy": "identity"
  },
  "feature_extraction": {
    "family": "minirocket",
    "kernel_length": 7,
    "num_kernels": 1000,
    "random_state": 42
  },
  "model": {
    "alphas": [
      0.001,
      0.01,
      0.1,
      1.0,
      10.0,
      100.0,
      1000.0
    ],
    "family": "ridge_regressor_cv"
  },
  "name": "iter1_minirocket_free_sharp",
  "preprocessing": {
    "normalize": "per_channel_zscore"
  },
  "training": {
    "loss": "ridge_regression_cv",
    "seed": 42
  }
}