{
  "calibration": {
    "cal_fraction": 0.2,
    "mode": "per_subject"
  },
  "data": {
    "signals": [
      "ppg"
    ],
    "val_fraction": 0.2
  },
  "decode": {
    "strategy": "identity"
  },
  "feature_extraction": null,
  "model": {
    "dim": 96,
    "dropout": 0.2,
    "family": "mamba_ssm",
    "n_layers": 3
  },
  "name": "iter1_mamba_ssm_cal_wide",
  "preprocessing": {
    "normalize": "per_channel_zscore"
  },
  "training": {
    "batch_size": 64,
    "epochs": 40,
    "loss": "smooth_l1",
    "lr": 0.0003,
    "optimizer": "adamw",
    "seed": 42
  }
}