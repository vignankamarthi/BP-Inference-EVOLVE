{
  "calibration": {
    "cal_fraction": 0.2,
    "mode": "per_subject"
  },
  "data": {
    "signals": [
      "ppg"
    ],
    "val_fraction": 0.2
  },
  "decode": {
    "strategy": "identity"
  },
  "feature_extraction": null,
  "model": {
    "d_model": 64,
    "downsample": 8,
    "dropout": 0.2,
    "family": "transformer1d",
    "n_heads": 4,
    "n_layers": 3
  },
  "name": "screen_transformer1d",
  "preprocessing": {
    "normalize": "per_channel_zscore"
  },
  "training": {
    "batch_size": 64,
    "epochs": 40,
    "loss": "smooth_l1",
    "lr": 0.0005,
    "optimizer": "adamw",
    "seed": 42
  }
}