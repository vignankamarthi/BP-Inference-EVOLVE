{
  "calibration": {
    "cal_fraction": 0.2,
    "mode": "per_subject"
  },
  "data": {
    "signals": [
      "ppg"
    ],
    "val_fraction": 0.2
  },
  "decode": {
    "strategy": "identity"
  },
  "feature_extraction": null,
  "model": {
    "base_channels": 32,
    "blocks_per_stage": 2,
    "dropout": 0.2,
    "family": "xresnet1d",
    "n_stages": 4
  },
  "name": "screen_xresnet1d",
  "preprocessing": {
    "normalize": "per_channel_zscore"
  },
  "training": {
    "batch_size": 64,
    "epochs": 40,
    "loss": "smooth_l1",
    "lr": 0.0005,
    "optimizer": "adamw",
    "seed": 42
  }
}