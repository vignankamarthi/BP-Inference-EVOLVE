{
  "calibration": {
    "cal_fraction": 0.2,
    "mode": "per_subject"
  },
  "data": {
    "signals": [
      "ppg"
    ],
    "val_fraction": 0.2
  },
  "decode": {
    "strategy": "identity"
  },
  "feature_extraction": null,
  "model": {
    "channels": 48,
    "dropout": 0.2,
    "family": "tcn",
    "kernel_size": 7,
    "n_blocks": 6
  },
  "name": "screen_tcn",
  "preprocessing": {
    "normalize": "per_channel_zscore"
  },
  "training": {
    "batch_size": 64,
    "epochs": 40,
    "loss": "smooth_l1",
    "lr": 0.0005,
    "optimizer": "adamw",
    "seed": 42
  }
}